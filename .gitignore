*.py[cod]
.venv/
venv/

# Datasets and run outputs — regenerate with the scripts, don't commit.
# Leading slash anchors these to the repo root. Without it, "data/" also
# matches src/aksara/data/ and silently drops the entire data module.
/data/
/artifacts/
/artifacts_*/
*.pth
*.ckpt

# Cleaning changelogs are ~6MB of per-file rows, regenerated by
# 06_clean_dataset.py. The rules file (committed) is the provenance record;
# the changelog is its output.
configs/cleaning_changelog*.csv

.ipynb_checkpoints/
.DS_Store

# Preloaded uint8 image arrays — rebuilt on demand, large.
preload_cache/
